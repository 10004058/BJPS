import pandas as pd
from openai import OpenAI

client = OpenAI()

df = pd.read_csv("Corpus.csv", header=None) #Update with the name of the CSV with the occurrences

sentence_column = df.columns[0]

sentences = df[sentence_column].dropna().astype(str).tolist()

print("Using column:", sentence_column)
print("Number of sentences:", len(sentences))

results = []

batch_size = 500

for i in range(0, len(sentences), batch_size):
    batch = sentences[i:i + batch_size]

    response = client.embeddings.create(
        model="text-embedding-3-small",
        input=batch,
        encoding_format="float"
    )

    embeddings = [item.embedding for item in response.data]
    results.extend(embeddings)

df["embedding"] = results

df.to_csv("sentences_embeddings.csv",index=False)

print(df.head())
